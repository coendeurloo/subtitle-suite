    <!-- ======== 3. AI Translation ======== -->
    <category id="ai_translation" label="33058">
      <group id="ai_settings" label="33058">
        <setting id="enable_ai_translation" type="boolean" label="33059">
          <help>33063</help>
          <level>0</level>
          <default>false</default>
          <control type="toggle"/>
        </setting>
        <setting id="openai_api_key" type="string" label="33060">
          <level>0</level>
          <default></default>
          <control type="edit" format="string"></control>
        </setting>
        <setting id="openai_model" type="string" label="33061">
          <level>1</level>
          <default>gpt-4.1-mini</default>
          <dependencies>
            <dependency type="visible" setting="enable_ai_translation">true</dependency>
          </dependencies>
          <control type="edit" format="string"></control>
        </setting>
      </group>
    </category>

    <!-- ======== 4. When Subtitles Are Missing ======== -->
    <category id="missing" label="33047">
      <group id="missing_behavior" label="33047">
        <setting id="no_match_behavior" type="string" label="33020">
          <help>33054</help>
          <level>0</level>
          <default>33022</default>
          <constraints>
            <options>
              <option label="33022">33022</option>
              <option label="33023">33023</option>
              <option label="33024">33024</option>
            </options>
          </constraints>
          <control type="list" format="string"/>
        </setting>
        <setting id="partial_match_behavior" type="string" label="33021">
          <help>33055</help>
          <level>0</level>
          <default>33025</default>
          <constraints>
            <options>
              <option label="33025">33025</option>
              <option label="33026">33026</option>
              <option label="33027">33027</option>
            </options>
          </constraints>
          <control type="list" format="string"/>
        </setting>
        <setting id="second_subtitle_required" type="boolean" label="33028">
          <help>33056</help>
          <level>0</level>
          <default>false</default>
          <control type="toggle"/>
        </setting>
        <setting id="last_used_subtitle_dir" type="string" label="">
          <level>100</level>
          <default></default>
          <visible>false</visible>
          <control type="edit" format="string"></control>
        </setting>
      </group>
    </category>

    <!-- ======== 5. Timing ======== -->
    <category id="timing" label="33049">
      <group id="smart_sync" label="33081">
        <setting id="enable_smart_sync" type="boolean" label="33081">
          <help>33082</help>
          <level>0</level>
          <default>true</default>
          <control type="toggle"/>
        </setting>
        <setting id="smart_sync_mode" type="string" label="33145">
          <level>0</level>
          <default>33147</default>
          <dependencies>
            <dependency type="visible" setting="enable_smart_sync">true</dependency>
          </dependencies>
          <constraints>
            <options>
              <option label="33147">33147</option>
              <option label="33146">33146</option>
            </options>
          </constraints>
          <control type="list" format="string"/>
        </setting>
      </group>

      <group id="auto_shift" label="32520">
        <setting id="autoShft" type="boolean" label="32520">
          <help>32522</help>
          <level>0</level>
          <default>true</default>
          <control type="toggle"/>
        </setting>
        <setting id="autoShftAmt" type="integer" label="32521">
          <level>0</level>
          <default>500</default>
          <dependencies>
            <dependency type="visible" setting="autoShft">true</dependency>
          </dependencies>
          <constraints>
            <minimum>50</minimum>
            <step>50</step>
            <maximum>5000</maximum>
          </constraints>
          <control type="edit" format="integer"/>
        </setting>
      </group>

      <group id="min_time" label="32526">
        <setting id="minTime" type="integer" label="32526">
          <help>32527</help>
          <level>0</level>
          <default>0</default>
          <constraints>
            <minimum>0</minimum>
            <step>100</step>
            <maximum>10000</maximum>
          </constraints>
          <control type="edit" format="integer"/>
        </setting>
      </group>
    </category>


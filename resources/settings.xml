    <!-- ======== 2. Subtitle Sources ======== -->
    <category id="sources" label="33163">
      <group id="download_general" label="33163">
        <setting id="enable_subtitle_download" type="boolean" label="33164">
          <help>33171</help>
          <level>0</level>
          <default>true</default>
          <control type="toggle"/>
        </setting>
        <setting id="download_auto_on_missing" type="boolean" label="33165">
          <level>0</level>
          <default>true</default>
          <control type="toggle"/>
        </setting>
        <setting id="download_max_results" type="integer" label="33170">
          <level>1</level>
          <default>12</default>
          <constraints>
            <minimum>1</minimum>
            <maximum>50</maximum>
          </constraints>
          <control type="edit" format="integer"/>
        </setting>
      </group>

      <group id="provider_opensubtitles" label="33166">
